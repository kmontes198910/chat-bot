    {
      "parameters": {
        "jsCode": "const execData = $input.first().json;\n\nlet waId = null;\ntry {\n  const runData = execData?.data?.resultData?.runData;\n  const waTriggerRun = runData?.['WA Trigger'];\n  waId = waTriggerRun?.[0]?.data?.main?.[0]?.[0]?.json?.contacts?.[0]?.wa_id ?? null;\n} catch (e) {}\n\nconst errorExec = $('Error Trigger').item.json;\n\nreturn [{\n  json: {\n    wa_id: waId,\n    execution_id: errorExec.execution?.id ?? 'unknown',\n    error_message: errorExec.execution?.error?.message ?? 'Unknown error',\n    last_node: errorExec.execution?.lastNodeExecuted ?? 'unknown',\n    workflow_name: errorExec.workflow?.name ?? 'unknown'\n  }\n}];"
      },
