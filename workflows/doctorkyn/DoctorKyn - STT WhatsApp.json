    },
    {
      "parameters": {
        "jsCode": "// Valida calidad de la transcripción — descarta ruido / artefactos de Whisper\nconst text = ($json.text || '').trim();\n// Whisper emite [BLANK_AUDIO], [música], [RUIDO], [silencio], etc. cuando no hay habla clara\nconst isArtifact = /^\\[.+\\]$/.test(text);\n// Mínimo 2 palabras reales con al menos 2 caracteres cada una\nconst words = text.split(/\\s+/).filter(w => w.length >= 2);\nconst isValid = text.length >= 5 && !isArtifact && words.length >= 2;\nreturn [{ json: { text, isValid } }];"
      },
      "id": "d1818b97-4d6d-4b29-b6b6-f887aaf93283",
      "name": "Validate Transcription",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1152,
        -192
      ]
    },
