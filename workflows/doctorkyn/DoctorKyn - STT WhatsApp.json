              "id": "0dad8b6b-bd9e-4bb4-9c2c-68889dd33b47",
              "leftValue": "={{ $json.isValid }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "17b5267c-ed98-4816-8e96-07bd5c83eccf",
      "name": "IF Transcription Valid",
