# n8n-MCP Docker Environment Configuration
# Copy this file to .env and fill in your actual values

# n8n API Configuration
N8N_API_URL=https://n8n.kynsoft.net
N8N_API_KEY=your-n8n-api-key-here

# MCP Server Configuration (for HTTP mode)
MCP_AUTH_TOKEN=your-secure-mcp-auth-token-here

# Optional: Telemetry (set to true to disable)
N8N_MCP_TELEMETRY_DISABLED=true

# Optional: For local n8n development
# N8N_API_URL=http://host.docker.internal:5678
# WEBHOOK_SECURITY_MODE=moderate
