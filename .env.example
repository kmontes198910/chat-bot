# n8n Environment Configuration
# Copy this file to .env and fill in your actual values

# ── n8n Instance ─────────────────────────────────────────────────────────────
# N8N_API_URL  → used by the Docker MCP container
# N8N_HOST     → used by the n8n-api-* skills (direct REST API calls)
# Both should point to the same instance.
N8N_API_URL=https://your-n8n-instance.example.com
N8N_HOST=https://your-n8n-instance.example.com
N8N_API_KEY=your-n8n-api-key-here

# ── MCP Server (Docker container) ────────────────────────────────────────────
MCP_AUTH_TOKEN=your-secure-mcp-auth-token-here
MCP_MODE=http
MCP_PORT=3000

# ── Optional ──────────────────────────────────────────────────────────────────
N8N_MCP_TELEMETRY_DISABLED=true
LOG_LEVEL=error
